# Runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# Firebase (Admin SDK)
FIREBASE_PROJECT_ID=geopulse
FIREBASE_CLIENT_EMAIL=sa@geopulse.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# IP intelligence: ipapi | ipwho (ipmeta reserved/disabled)
IP_PROVIDER=ipapi

# CoinGecko
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_DEMO_KEY=

# News
CRYPTOCOMPARE_API_KEY=REPLACE_ME
GNEWS_API_KEY=

# Cache
CACHE_ENABLED=true

# Auth (Firebase ID tokens). Set false only for local/dev — never in production.
AUTH_ENABLED=true
